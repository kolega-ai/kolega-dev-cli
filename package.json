{
  "name": "@kolegaai/cli",
  "version": "1.0.0",
  "description": "Command-line interface for the Kolega.dev public API.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "kolega": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "generate-types": "tsx scripts/generate-types.ts",
    "build": "tsc -p .",
    "postbuild": "node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run generate-types && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "inquirer": "^9.3.7",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "undici": "^6.20.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "openapi-typescript": "^7.4.1",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "vitest": "^2.1.2"
  }
}
